---
interface Props {
  /** Regular share URL: YouTube watch/shorts/youtu.be, TikTok video,
      Instagram reel/post — or a ready-made embed URL for anything else. */
  url: string;
  /** Accessible title for the iframe (shown to screen readers). */
  title: string;
  orientation?: "horizontal" | "vertical";
  /** Optional annotation rendered as a sticky note over the frame. */
  note?: string;
}

const { url, title, orientation = "horizontal", note } = Astro.props;

function toEmbedUrl(raw: string): string {
  const u = new URL(raw);
  const host = u.hostname.replace(/^www\./, "");
  if (host === "youtu.be") {
    return `https://www.youtube-nocookie.com/embed/${u.pathname.slice(1)}`;
  }
  if (host.endsWith("youtube.com")) {
    if (u.pathname.startsWith("/embed/")) return raw;
    if (u.pathname.startsWith("/shorts/") || u.pathname.startsWith("/live/")) {
      return `https://www.youtube-nocookie.com/embed/${u.pathname.split("/")[2]}`;
    }
    const id = u.searchParams.get("v");
    if (id) return `https://www.youtube-nocookie.com/embed/${id}`;
  }
  if (host.endsWith("tiktok.com")) {
    const m = u.pathname.match(/\/video\/(\d+)/);
    if (m) return `https://www.tiktok.com/embed/v2/${m[1]}`;
  }
  if (host.endsWith("instagram.com")) {
    const m = u.pathname.match(/\/(reel|p)\/([^/]+)/);
    if (m) return `https://www.instagram.com/${m[1]}/${m[2]}/embed/captioned/`;
  }
  return raw;
}

const src = toEmbedUrl(url);
---

<figure class:list={["video", orientation]}>
  {note && <figcaption class="note">{note}</figcaption>}
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allowfullscreen
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
  ></iframe>
</figure>

<style>
  .video {
    position: relative;
    margin: 0 0 var(--space-3);
  }

  .video.horizontal {
    aspect-ratio: 16 / 9;
  }

  .video.vertical {
    aspect-ratio: 9 / 16;
  }

  .video iframe {
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 4px;
    background: #000;
  }

  .note {
    position: absolute;
    z-index: 1;
    top: -0.7rem;
    left: 0.75rem;
    max-width: 75%;
    transform: rotate(-1.5deg);
    background: color-mix(in srgb, var(--color-accent) 14%, var(--color-bg));
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    line-height: 1.4;
    padding: 0.35em 0.65em;
    border-radius: 2px;
    box-shadow: 0 1px 3px rgba(31, 28, 26, 0.18);
  }
</style>
