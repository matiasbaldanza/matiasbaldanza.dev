    <h1>Matías Baldanza</h1>
    <p class="tagline">
      Developer Relations Engineer · Technical Content · Developer Education<br
      />
      Argentina (remote, US-hours compatible)
    </p>
    <p class="meta">
      <a
        href="mailto:matiasbaldanza@gmail.com?subject=CV%20DevRel%20Engineer%20dotCMS%202026%20from%20site"
        >Email</a
      >{" · "}
      <a href="https://linkedin.com/in/matiasbaldanza">LinkedIn</a>{" · "}
      <a href="https://github.com/matiasbaldanza">GitHub</a>{" · "}
      <a href="https://x.com/matiasbaldanza">X/Twitter</a>{" · "}
      <a href="/cv/matias-baldanza-cv-dotcms.pdf">Download PDF</a>
    </p>
