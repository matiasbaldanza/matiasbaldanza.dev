---
import DotcmsLayout from "../../layouts/DotcmsLayout.astro";

const skills = [
  {
    title: "Frontend & APIs",
    items:
      "JavaScript, TypeScript, React, Next.js, Astro; REST & GraphQL API integration, auth flows, SDK-based development",
  },
  {
    title: "CMS & Content Platforms",
    items: "Contentful, Sanity, Strapi, Directus, Payload, Ghost, WordPress",
  },
  {
    title: "Infra & tooling",
    items:
      "Linux, Docker/Compose, Nginx, Caddy, GitHub Actions, PostgreSQL, VPS/cloud deployment",
  },
  {
    title: "AI developer workflows",
    items:
      "Claude Code, Codex, MCP servers, RAG pipelines, evals, local models, agent-friendly documentation",
  },
  {
    title: "Content & community",
    items:
      "technical writing, documentation, screencasts, livestreaming (OBS), video editing (Final Cut Pro/Premiere), Remotion, workshops, developer forums; bilingual EN (C2) / ES (native)",
  },
  {
    title: "Backend",
    items: "Node, Express, Hono, FastAPI, Python, PostgreSQL",
  },
];
