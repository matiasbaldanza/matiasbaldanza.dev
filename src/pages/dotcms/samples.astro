---
import DotcmsLayout from "../../layouts/DotcmsLayout.astro";
import VideoEmbed from "../../components/dotcms/VideoEmbed.astro";
import WorkshopItem from "../../components/dotcms/WorkshopItem.astro";
import PageToc from "../../components/PageToc.astro";

// ---------------------------------------------------------------------------
// Content lives here. Paste regular share URLs (YouTube watch/shorts,
// youtu.be, TikTok video, Instagram reel) — VideoEmbed derives the embed URL.
// `note` is optional everywhere: add it and a sticky-note annotation appears
// over the video frame; omit it and nothing renders.
// Sections only show up when their array has items.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// MASTER SWITCH — set to true to render the content arrays below, false to
// hide them all (sections disappear, only the header + note remain).
// Keep false in deploys until the DEMO placeholders are replaced.
// ---------------------------------------------------------------------------
const showContent = true;

type Video = { url: string; title: string; note?: string; isNew?: boolean };

// Long-form videos and tutorials (horizontal, 16:9)
// Placeholders below — replace url/title/note with real content, keep the shape.
const longForm: Video[] = [
  {
    url: "https://www.youtube.com/watch?v=dsTXcSeAZq8",
    title: "DEMO — long-form tutorial",
    note: "DEMO note: this is what an annotation looks like.",
    isNew: true,
  },
  {
    url: "https://www.youtube.com/watch?v=XoTwXcqIqvs",
    title: "DEMO — long-form without a note",
  },
];

// Live workshop recordings (horizontal, 16:9)
const workshopVideos: Video[] = [
  {
    url: "https://youtu.be/dsTXcSeAZq8",
    title: "DEMO — workshop recording",
    note: "DEMO: workshop notes go here.",
  },
];

// Short-form vertical video (TikTok / Instagram / YouTube Shorts, 9:16)
const shortForm: Video[] = [
  {
    url: "https://www.youtube.com/shorts/kRuTMWSyMLA",
    title: "DEMO — vertical 1",
    note: "DEMO vertical note",
  },
  {
    url: "https://www.youtube.com/shorts/kRuTMWSyMLA",
    title: "DEMO — vertical 2",
  },
  {
    url: "https://www.youtube.com/shorts/kRuTMWSyMLA",
    title: "DEMO — vertical 3",
  },
];

// Workshop history — dates and short specs
type Workshop = {
  title: string;
  date: string;
  description: string;
  isNew?: boolean;
};

const workshopHistory: Workshop[] = [
  {
    title: "DEMO — Docker desde cero",
    date: "2024-08",
    description:
      "Two-hour live session: images, containers, volumes, and compose, ending with a deployed app. 300+ sign-ups.",
  },
  {
    title: "DEMO — CI/CD con GitHub Actions",
    date: "2024-10",
    description:
      "Pipelines from scratch: build, test, and deploy to a VPS on every push, with rollback strategies.",
  },
  {
    title: "DEMO — Deploy de apps con Nginx y SSL",
    date: "2025-02",
    description:
      "Reverse proxies, Let's Encrypt certificates, and zero-downtime reloads, live and unscripted.",
    isNew: true,
  },
];

// ---------------------------------------------------------------------------
// Dev-only skeleton mode: flip to `&& true` to append the demo entries below
// in `npm run dev` (e.g. to preview layout with more items than you have).
// import.meta.env.DEV is false in `astro build`, so demo entries can never
// reach production either way.
// ---------------------------------------------------------------------------
const showDemo = import.meta.env.DEV && false;

const demo: {
  longForm: Video[];
  workshopVideos: Video[];
  shortForm: Video[];
  workshopHistory: Workshop[];
} = {
  longForm: [
    {
      url: "https://www.youtube.com/watch?v=dsTXcSeAZq8",
      title: "DEMO — long-form tutorial",
      note: "DEMO note: this is what an annotation looks like.",
    },
    {
      url: "https://www.youtube.com/watch?v=XoTwXcqIqvs",
      title: "DEMO — long-form without a note",
    },
  ],
  workshopVideos: [
    {
      url: "https://youtu.be/dsTXcSeAZq8",
      title: "DEMO — workshop recording",
      note: "DEMO: workshop notes go here.",
    },
  ],
  shortForm: [
    {
      url: "https://www.youtube.com/shorts/kRuTMWSyMLA",
      title: "DEMO — vertical 1",
      note: "DEMO vertical note",
    },
    {
      url: "https://www.youtube.com/shorts/kRuTMWSyMLA",
      title: "DEMO — vertical 2",
    },
    {
      url: "https://www.youtube.com/shorts/kRuTMWSyMLA",
      title: "DEMO — vertical 3",
    },
  ],
  workshopHistory: [
    {
      title: "DEMO — Docker desde cero",
      date: "2024-08",
      description:
        "Two-hour live session: images, containers, volumes, and compose, ending with a deployed app. 300+ sign-ups.",
    },
    {
      title: "DEMO — CI/CD con GitHub Actions",
      date: "2024-10",
      description:
        "Pipelines from scratch: build, test, and deploy to a VPS on every push, with rollback strategies.",
    },
    {
      title: "DEMO — Deploy de apps con Nginx y SSL",
      date: "2025-02",
      description:
        "Reverse proxies, Let's Encrypt certificates, and zero-downtime reloads, live and unscripted.",
    },
  ],
};

const longFormAll = [
  ...(showContent ? longForm : []),
  ...(showDemo ? demo.longForm : []),
];
const workshopVideosAll = [
  ...(showContent ? workshopVideos : []),
  ...(showDemo ? demo.workshopVideos : []),
];
const shortFormAll = [
  ...(showContent ? shortForm : []),
  ...(showDemo ? demo.shortForm : []),
];
const workshopHistoryAll = [
  ...(showContent ? workshopHistory : []),
  ...(showDemo ? demo.workshopHistory : []),
];

// "On this page" anchor row — only sections that actually render.
const sections = [
  { id: "long-form", label: "Long-form", count: longFormAll.length },
  {
    id: "live-workshops",
    label: "Live workshops",
    count: workshopVideosAll.length,
  },
  { id: "short-form", label: "Short-form", count: shortFormAll.length },
  {
    id: "workshop-history",
    label: "Workshop history",
    count: workshopHistoryAll.length,
  },
].filter((s) => s.count > 0);
---

<DotcmsLayout
  title="Work samples — Matías Baldanza"
  description="Video, workshops, and technical content samples by Matías Baldanza."
>
  <header class="top">
    <h1>Work samples</h1>
    <p class="meta">
      A hand-picked selection — video, live workshops, and short-form content.
    </p>
  </header>

  <p class="subtitle">
    Uh, oh! I’m currently curating samples and will be uploading them in a few
    hours. Below I'll be adding a growing selection, not the finished gallery.
    🚧 Check back soon and, sorry for the inconvenience! 🚧
  </p>

  <PageToc sections={sections} sticky />

  {
    longFormAll.length > 0 && (
      <>
        <h2 id="long-form">Long-form video &amp; tutorials</h2>
        {longFormAll.map((v) => (
          <VideoEmbed
            url={v.url}
            title={v.title}
            note={v.note}
            isNew={v.isNew}
          />
        ))}
      </>
    )
  }

  {
    workshopVideosAll.length > 0 && (
      <>
        <h2 id="live-workshops">Live workshops</h2>
        {workshopVideosAll.map((v) => (
          <VideoEmbed
            url={v.url}
            title={v.title}
            note={v.note}
            isNew={v.isNew}
          />
        ))}
      </>
    )
  }

  {
    shortFormAll.length > 0 && (
      <>
        <h2 id="short-form">Short-form video</h2>
        <div class="vertical-grid">
          {shortFormAll.map((v) => (
            <VideoEmbed
              url={v.url}
              title={v.title}
              note={v.note}
              isNew={v.isNew}
              orientation="vertical"
            />
          ))}
        </div>
      </>
    )
  }

  {
    workshopHistoryAll.length > 0 && (
      <>
        <h2 id="workshop-history">Workshop history</h2>
        <p class="meta">Click any row for the session spec.</p>
        <div class="workshop-list">
          {workshopHistoryAll.map((w) => (
            <WorkshopItem
              title={w.title}
              date={w.date}
              description={w.description}
              isNew={w.isNew}
            />
          ))}
        </div>
      </>
    )
  }

  <p slot="footer">
    <a href="/dotcms">← Back to the intro</a>{" · "}
    <a href="/dotcms/resume">resumé</a>{" · "}
    <a href="mailto:matiasbaldanza@gmail.com">matiasbaldanza@gmail.com</a>
  </p>
</DotcmsLayout>

<style>
  .top {
    padding-top: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .top .meta {
    margin-top: 0.4rem;
  }

  .vertical-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-3) var(--space-2);
  }

  .workshop-list {
    border-top: 1px solid var(--color-rule);
    margin-bottom: var(--space-3);
  }
</style>
