---
import MainLayout from "../layouts/MainLayout.astro"
import SocialLinks from "../components/SocialLinks.astro"
import EmailLink from "../components/EmailLink.astro"
import { videoLinks } from "../data/video-links"

const nowUpdated = "July 2026"

const videoTypeLabels: Record<(typeof videoLinks)[number]["type"], string> = {
  short: "Short",
  long: "Long-form",
  stream: "Stream",
}
---

<MainLayout
  title="Matías Baldanza — Developer Relations & Technical Content"
  description="Hands-on DevRel engineer: working demos, docs and tutorials, workshops, and video — in English and Spanish."
>
  <aside id="way-back-banner" class="way-back-banner" hidden>
    Hey 👋. I believe you came here through <a href="/dotcms">my pitch</a>.
    Since that's an unlisted page, here's your way back.
  </aside>

  <section class="hero">
    <img
      class="avatar"
      src="/images/avatar.jpg"
      alt="Matías Baldanza"
      width="112"
      height="112"
    />
    <h1>Matías Baldanza</h1>
    <p class="tagline">
      Developer Relations · Technical Content · Developer Education
    </p>
    <p>
      I research developer tools, build working demos, write the docs and
      tutorials that explain them, and get in front of developers — on camera,
      in live workshops, and in writing. In English and Spanish.
    </p>
    <SocialLinks />
    <p class="meta contact">
      Argentina-based (remote, US-hours compatible) {" · "}
      <EmailLink label="Email me" /> {" · "}
      <a href="/work">Work with me</a>
    </p>
  </section>

  <section class="home-section" aria-labelledby="now-heading">
    <h2 id="now-heading">Now</h2>
    <p>
      Building out this site, streaming the process on Twitch, and taking on
      freelance content and consulting work. Updated {nowUpdated}.
    </p>
    <p class="meta section-more">
      <a href="/now">Full now page →</a>
    </p>
  </section>

  <section class="home-section" aria-labelledby="writing-heading">
    <h2 id="writing-heading">Latest writing</h2>
    <p class="empty-state">Articles coming soon — tutorials, demos, and DevRel notes in English and Spanish.</p>
    <p class="meta section-more">
      <span class="muted">/writing</span> — Phase 1
    </p>
  </section>

  <section class="home-section" aria-labelledby="video-heading">
    <h2 id="video-heading">Video</h2>
    {
      videoLinks.length > 0 ? (
        <ul class="link-list">
          {videoLinks.map((item) => (
            <li>
              <a href={item.href}>{item.title}</a>
              <span class="item-meta">
                {" "}
                · {videoTypeLabels[item.type]} · {item.platform}
              </span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">
          Short and long-form videos on YouTube and Twitch — links will appear
          here as I publish.
        </p>
      )
    }
  </section>

  <section class="home-section" aria-labelledby="work-heading">
    <h2 id="work-heading">Work with me</h2>
    <p>
      Freelance technical writing, demo builds, workshops, and per-issue
      consulting for developer-tool companies — in English or Spanish.
    </p>
    <p class="meta section-more">
      <a href="/work">Details &amp; how to reach me →</a>
    </p>
  </section>

  {
    /* Reveals the way-back banner for visitors who entered through an
      unlisted pitch page (marker set in DotcmsLayout). No marker, no JS,
      or storage blocked → the banner simply stays hidden. */
  }
  <script is:inline>
    try {
      const raw = sessionStorage.getItem("unlisted-entry");
      if (raw) {
        const { label, href } = JSON.parse(raw);
        const banner = document.getElementById("way-back-banner");
        const link = banner.querySelector("a");
        link.href = href;
        link.textContent = label;
        banner.hidden = false;
      }
    } catch {}
  </script>
</MainLayout>

<style>
  .way-back-banner {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    background: #fff;
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    padding: 0.55rem 0.75rem;
    text-align: center;
    margin-bottom: var(--space-3);
    text-wrap: balance;
  }

  .way-back-banner a {
    color: var(--color-accent);
  }

  .hero {
    padding-top: var(--space-3);
  }

  .avatar {
    margin-bottom: var(--space-3);
  }

  .tagline {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: var(--color-muted);
    margin-top: 0.4rem;
    margin-bottom: var(--space-3);
  }

  .contact {
    margin-top: var(--space-3);
  }
</style>
